{
  "manifest_version": 3,
  "name": "EngageAI",
  "version": "0.1.0",
  "description": "AI-powered social media reply assistant",
  "permissions": ["activeTab", "storage", "alarms", "scripting", "tabs", "sidePanel"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.threads.net/*",
    "https://www.threads.com/*",
    "https://threads.net/*",
    "https://threads.com/*",
    "https://x.com/*",
    "https://www.linkedin.com/*",
    "https://www.tiktok.com/*",
    "https://engageai-coral.vercel.app/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/16.png", "icons/48.png"],
      "matches": ["https://www.linkedin.com/*", "https://www.instagram.com/*", "https://www.threads.net/*", "https://www.threads.com/*", "https://threads.net/*", "https://threads.com/*", "https://x.com/*", "https://www.tiktok.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content-instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.threads.net/*", "https://www.threads.com/*", "https://threads.net/*", "https://threads.com/*"],
      "js": ["content-threads.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*"],
      "js": ["content-x.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content-linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["content-tiktok.js"],
      "run_at": "document_idle"
    }
  ]
}
